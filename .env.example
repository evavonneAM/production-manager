# Copy this file to ".env" and fill in real values. ".env" is git-ignored.
# In Vite, only variables prefixed with VITE_ are exposed to the browser.

# Supabase — from your project's API settings (Project Settings > API)
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Service-role (secret) key — used ONLY by local scripts/seed-data.mjs (npm run seed).
# This key bypasses Row-Level Security: never expose it to the browser or commit it.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# --- Added in later sprints (kept here so they are documented in one place) ---
# DeepL (Sprint 7) and Google service account (Sprint 9) live in Supabase
# Edge Function secrets, NOT here, because they must never reach the browser.
